FROM python:3.11-slim

WORKDIR /app

RUN apt-get update && apt-get install -y libpq-dev gcc git && rm -rf /var/lib/apt/lists/*

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY . .

CMD ["sh", "-c", "python -c 'from app.database.connection import engine, Base; from app.database.models import *; Base.metadata.create_all(bind=engine)' && uvicorn app.api.main:app --host 0.0.0.0 --port ${PORT:-8080}"]
